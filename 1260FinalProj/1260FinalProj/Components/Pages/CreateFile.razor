@page "/Createfile"
@using System.ComponentModel.DataAnnotations
@using _1260FinalProj.Models
@using System.IO
@rendermode InteractiveServer
@inject ILogger<CreateFile> Logger
@inject IWebHostEnvironment Env


<h1>CreateFile</h1>

<p>this page is to create a file, hopefully with individual text boxes for each field.</p>

<h3>Info Entry form</h3>


<EditForm Model="Model" OnValidSubmit="Submit" FormName="Model">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div>
        <label>
            Identifier:
            <InputNumber @bind-Value="Model!.ID" />
        </label>
    </div>
    <div>
        <label>
            Name:
            <InputText @bind-Value="Model!.Name" />
        </label>
    </div>
    <div>
        <label>
            Category:
            <InputText @bind-Value="Model!.Category" />
        </label>
    </div>
    <div>
        <label>
            Description:
            <InputTextArea @bind-Value="Model!.Description" />
        </label>
    </div>
    
    @* <div>
        <label>
            Production Date:
            <InputDate @bind-Value="Model!.LastUpdateDT" />
        </label>
    </div> *@ @*this isn't input, but does need to be considered*@
    <div>
        <button type="button" @onclick="Log">log</button>
        <button type="submit">Submit</button>
    </div>
</EditForm>

@if (!string.IsNullOrEmpty(StatusMessage))
{
    <p>@StatusMessage</p>
}

@code {

    string StatusMessage;

    // placeholder too store data?
    public Entities? PlaceHolder { get; set; } = new Entities
    {
        ID = 0,
        Name = string.Empty,
        Category = string.Empty,
        Description = string.Empty,
        LastUpdateDT = DateTime.Now, 
        LastUpdate = (int)DateTime.Now.Subtract(new DateTime(1970, 1, 1)).TotalSeconds

    };

    private Entities? Model { get; set; } = new Entities();

    protected override void OnInitialized() =>
        Model ??= new() { LastUpdateDT = DateTime.UtcNow };

    private void Log()
    {
        Logger.LogInformation("ID = {ID} Name = {Name}" + "Category = {Category}" + "Description = {Description}" + "Last Update: {LastUpdateDT}",
            Model?.ID, Model?.Name, Model?.Category, Model?.Description, Model?.LastUpdate);
    }
    private void Submit()
    {
        try
        {
            
            //ensure Entities folder under wwwroot exists and write there
            var entitiesDir = Path.Combine(Env.WebRootPath ?? Env.ContentRootPath, "Entities");
            Directory.CreateDirectory(entitiesDir);

            var fileName = $"entity_{Model?.Name}.txt";
            var filePath = Path.Combine(entitiesDir, fileName);

            var content = $"ID: {Model?.ID}|Name: {Model?.Name}|Category: {Model?.Category}|Description: {Model?.Description}|LastUpdate: {Model?.LastUpdateDT}";
            File.WriteAllText(filePath, content);

            StatusMessage = $"File created successfully at {filePath}";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }


    }



}
