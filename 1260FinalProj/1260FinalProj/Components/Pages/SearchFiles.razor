@page "/SearchFiles"
@rendermode InteractiveServer
@using System.Linq
@using System
@using System.IO
@using _1260FinalProj.Models
@using static _1260FinalProj.Logic.Searching
@inject IWebHostEnvironment Env


<h2>File Search</h2>

<form>
    <input @bind="searchName" placeholder="Enter file name..." />
    <button type="button" @onclick="FilterName">Search</button>
</form>
@* Textarea to display file content*@
@if (!string.IsNullOrEmpty(NameStatusMessage))
{
    <p>@NameStatusMessage</p>
}
@if (!string.IsNullOrEmpty(NAMEselectedFileContent))
{
    <div>
        <label>Result:</label>
        <textarea readonly style="width:100%;height:300px">@NAMEselectedFileContent</textarea>
    </div>
}

<form>
    <input @bind="searchID" placeholder="Enter file ID number..." />
    <button type="button" @onclick="FilterID">Search</button>
</form>

@if (!string.IsNullOrEmpty(IDStatusMessage))
{
    <p>@IDStatusMessage</p>
}
@if (!string.IsNullOrEmpty(IDselectedFileContent))
{
    <div>
        <label>Result:</label>
        <textarea readonly style="width:100%;height:300px">@IDselectedFileContent</textarea>
    </div>
}

<form>
    <input @bind="searchCategory" placeholder="Enter file Category..." />
    <button type="button" @onclick="FilterCategory">Search</button>
</form>

@if (!string.IsNullOrEmpty(CategoryStatusMessage))
{
    <p>@CategoryStatusMessage</p>
}

@if (!string.IsNullOrEmpty(CATselectedFileContent))
{
    <div>
        <label>Result:</label>
        <textarea readonly style="width:100%;height:300px">@CATselectedFileContent</textarea>
    </div>
}

@*I need:
    A text box to put in the search term, be that whatever is getting searched [check]
    A place to load or select the returned items(?)
    and a place to display the information, if not just load the full .txt file into the web page (maybe a large, read-only text area?)
*@


@code {

    private List<IBrowserFile> allFiles = new();
    private List<IBrowserFile> filteredFiles = new();
    private int searchID = 0;
    private string searchName = string.Empty;
    private string searchCategory = string.Empty;
    private string NAMEselectedFileContent = string.Empty;
    private string IDselectedFileContent = string.Empty;
    private string CATselectedFileContent = string.Empty;

    string IDStatusMessage = string.Empty;
    string NameStatusMessage = string.Empty;
    string CategoryStatusMessage = string.Empty;

    private void FilterName()
    {
        var entitiesDir = Path.Combine(Env.WebRootPath ?? Env.ContentRootPath, "Entities");
        Directory.CreateDirectory(entitiesDir);
        List<Entities> FoundFiles = SearchByName(searchName, entitiesDir);
        foreach(var result in FoundFiles)
        {
            NAMEselectedFileContent = result.FormatItem(result) + "\n";
            
        }

        NameStatusMessage = $"Searched for Name: {searchName}";
    }

    private void FilterID()
    {
        var entitiesDir = Path.Combine(Env.WebRootPath ?? Env.ContentRootPath, "Entities");
        Directory.CreateDirectory(entitiesDir);
        List<Entities> FoundFiles = SearchByID(searchID, entitiesDir);
        foreach (var result in FoundFiles)
        {
            IDselectedFileContent = result.FormatItem(result) + "\n";
            
        }
        IDStatusMessage = $"Searched for ID: {searchID}";
    }

    private void FilterCategory()
    {
        var entitiesDir = Path.Combine(Env.WebRootPath ?? Env.ContentRootPath, "Entities");
        Directory.CreateDirectory(entitiesDir);
        List<Entities> FoundFiles = SearchByCategory(searchCategory, entitiesDir);
        foreach (var result in FoundFiles)
        {
            CATselectedFileContent = result.FormatItem(result) + "\n";
            
        }
        CategoryStatusMessage = $"Searched for Category: {searchCategory}";
    }
}
