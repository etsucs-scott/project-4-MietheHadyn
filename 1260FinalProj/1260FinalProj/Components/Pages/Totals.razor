@page "/Totals"
@rendermode InteractiveServer
@using System.Linq
@using _1260FinalProj.Logic
@using _1260FinalProj.Models
@inject IWebHostEnvironment Env
@attribute [StreamRendering]

<h3>Totals</h3>

<table class="table">
    <thead>
        <tr>
            <th>Category</th>
            <th aria-label="Number of Entities ">Num. Entities</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in CatTotals.Any() ? CatTotals : CategoryNames.Cast<object>())
        {
            <tr>
                <td>@GetCategoryName(item)</td>
                <td>@GetCategoryValue(item)</td>
            </tr>
        }
    </tbody>
</table>

@code {
   
    List<string> CategoryNames = new List<string>() { "Person", "Place", "Thing", "Idea" };

   
    List<object> CatTotals = new List<object>();

    protected override async Task OnInitializedAsync()
    {
        //Simulate asynchronous loading to demonstrate streaming rendering
        await Task.Delay(500);

        //Call the searching logic — keep result unassumed and try to enumerate it
        var totalsRaw = new Searching().CategoryQTY("wwwroot/Entities", CategoryNames);

        if (totalsRaw is System.Collections.IEnumerable seq)
        {
            CatTotals = seq.Cast<object>().ToList();
        }
        else if (totalsRaw != null)
        {
            CatTotals = new List<object> { totalsRaw };
        }
        
    }

    //Helper to read category name from various possible shapes (string, KeyValuePair, obj w/ properties)
    private string GetCategoryName(object o)
    {
        if (o == null) return string.Empty;
        if (o is string s) return s;

        var t = o.GetType();

        var prop = t.GetProperty("Category") 
                   ?? t.GetProperty("Category")
                   ?? t.GetProperty("Key")
                   ?? t.GetProperty("Name");
        if (prop != null)
        {
            var val = prop.GetValue(o);
            return val?.ToString() ?? string.Empty;
        }

        //Fallback to ToString
        return o.ToString();
    }

    //Helper to read a numeric value from various possible shapes
    private string GetCategoryValue(object o)
    {
        if (o == null) return string.Empty;

        //If the item itself is a numeric type
        if (o is byte || o is short || o is int || o is long || o is float || o is double || o is decimal)
            return o.ToString();

        var t = o.GetType();

        var prop = t.GetProperty("value")
                   ?? t.GetProperty("Value")
                   ?? t.GetProperty("Count")
                   ?? t.GetProperty("Qty")
                   ?? t.GetProperty("Quantity")
                   ?? t.GetProperty("Amount");
        if (prop != null)
        {
            var val = prop.GetValue(o);
            return val?.ToString() ?? string.Empty;
        }

        
        return string.Empty;
    }
}
